NODE_ENV=development
PORT=3000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=go2cloud

# JWT — REQUIRED in production (app throws on boot if missing when NODE_ENV=production).
# Generate a strong one with: openssl rand -base64 48
JWT_SECRET=dev-only-insecure-secret

# CORS
FRONTEND_URL=http://localhost:3001
